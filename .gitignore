# ==========================================
# ESPHome & PlatformIO
# ==========================================
# ESPHome generates build environments and compiled firmware here
.esphome/
.pio/

# Ignore local secrets referenced by secrets.example.yaml
secrets.yaml

# ==========================================
# Python (Scripts & Unit Tests)
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.venv/
venv/
env/

# ==========================================
# Tooling, Linting & Testing Caches
# ==========================================
# Pytest caching (used in tests/unit/)
.pytest_cache/

# Ruff caching (defined by ruff.toml)
.ruff_cache/

# Coverage tracking (if added later)
.coverage
htmlcov/

# ==========================================
# C++ Native Tests & Build Artifacts
# ==========================================
# Artifacts from tests/native/build_and_run.sh and similar scripts
build/
*.o
*.out
*.exe
*.bin
*.elf
# The native test scripts emit extensionless host binaries next to their
# sources; ignore them by name (g++ -o <name> in build_and_run*.sh).
tests/native/vs2_transaction_harness
tests/native/engine_proof
tests/native/gwg_poke
tests/native/gwg_read
tests/native/vs2_guards
tests/native/vs1_write
tests/native/test_decode
tests/native/proof_extract
tests/native/proof_vs2_zero_payload
tests/native/proof_packet_vs2_response
tests/native/proof_scheduler
tests/native/proof_string_offset
tests/native/proof_ring_buffer

# ==========================================
# OS & IDEs
# ==========================================
# Mac / Windows system files
.DS_Store
Thumbs.db

# VS Code / JetBrains / PlatformIO IDE folders
.vscode/
.idea/
